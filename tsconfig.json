{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    // TypeScript 6.0 promotes the `baseUrl` deprecation to a hard error.
    // tsup's DTS step (rollup-plugin-dts) injects a synthetic `baseUrl`
    // into its internal program, so every package's `dts: true` build
    // fails under tsc 6.0 without this. Set once at the base so all
    // parcae packages inherit it (previously sprinkled ad-hoc on only
    // auth-betterauth + model, leaving backend/sdk/i18n/etc. broken).
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["node_modules", "dist", ".parcae"]
}
