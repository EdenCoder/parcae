{
  "name": "@parcae/auth-betterauth",
  "version": "0.8.0",
  "description": "Better Auth adapter for Parcae — self-hosted auth with your User model",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-auth": "^1.6.14",
    "pg": "^8.21.0",
    "pluralize": "^8.0.0"
  },
  "peerDependencies": {
    "@parcae/backend": "workspace:*",
    "@parcae/model": "workspace:*"
  },
  "devDependencies": {
    "@parcae/backend": "workspace:*",
    "@parcae/model": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/pluralize": "^0.0.33",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
