{
  "name": "@parcae/lynx",
  "version": "0.1.0",
  "description": "Lynx / ReactLynx bindings for Parcae — live query stores and session lifecycle over the SDK wire protocol",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./store": {
      "types": "./dist/live-query.d.ts",
      "import": "./dist/live-query.js",
      "default": "./dist/live-query.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/live-query.ts --format esm --dts --sourcemap --clean --out-dir dist",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@parcae/model": "workspace:*"
  },
  "peerDependencies": {
    "@lynx-js/react": ">=0.111.0",
    "@parcae/sdk": "workspace:*"
  },
  "devDependencies": {
    "@lynx-js/react": "^0.116.2",
    "@lynx-js/types": "^3.8.0",
    "@parcae/sdk": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "license": "MIT"
}
