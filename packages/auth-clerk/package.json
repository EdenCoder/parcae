{
  "name": "@parcae/auth-clerk",
  "version": "0.8.0",
  "description": "Clerk adapter for Parcae — external auth proxied to your User model",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clerk/backend": "^3.7.1",
    "svix": "^1.95.2"
  },
  "peerDependencies": {
    "@parcae/backend": "workspace:*",
    "@parcae/model": "workspace:*",
    "@parcae/sdk": "workspace:*"
  },
  "devDependencies": {
    "@parcae/backend": "workspace:*",
    "@parcae/model": "workspace:*",
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "license": "MIT"
}
