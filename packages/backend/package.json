{
  "name": "@parcae/backend",
  "version": "0.8.1",
  "description": "Parcae Backend — TypeScript backend framework with auto-CRUD, realtime, and jobs",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "parcae": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@parcae/model": "workspace:*",
    "@sesamecare-oss/redlock": "^1.1.0",
    "async-lock": "^1.4.1",
    "better-sqlite3": "^11.0.0",
    "body-parser": "^1.20.3",
    "bullmq": "^5.0.0",
    "compress-json": "^3.1.0",
    "croner": "^9",
    "deep-equal": "^2.2.3",
    "eventemitter3": "^5.0.1",
    "fast-json-patch": "^3.1.1",
    "ioredis": "^5.4.0",
    "knex": "^3.1.0",
    "pako": "^2.1.0",
    "pg": "^8.20.0",
    "pluralize": "^8.0.0",
    "polka": "^0.5.2",
    "socket.io": "^4.8.0",
    "ts-morph": "^27.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/async-lock": "^1.4.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/body-parser": "^1.19.5",
    "@types/deep-equal": "^1.0.4",
    "@types/node": "^22.0.0",
    "@types/pako": "^2.0.3",
    "@types/pg": "^8.11.0",
    "@types/pluralize": "^0.0.33",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
