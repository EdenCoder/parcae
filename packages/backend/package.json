{
  "name": "@parcae/backend",
  "version": "0.8.1",
  "description": "Parcae Backend — TypeScript backend framework with auto-CRUD, realtime, and jobs",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "parcae": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@parcae/model": "workspace:*",
    "@sesamecare-oss/redlock": "^1.4.0",
    "async-lock": "^1.4.1",
    "better-sqlite3": "^12.10.0",
    "body-parser": "^2.2.2",
    "bullmq": "^5.78.0",
    "compress-json": "^3.4.0",
    "croner": "^10.0.1",
    "deep-equal": "^2.2.3",
    "eventemitter3": "^5.0.4",
    "fast-json-patch": "^3.1.1",
    "ioredis": "^5.11.0",
    "knex": "^3.2.10",
    "pako": "^2.1.0",
    "pg": "^8.21.0",
    "pluralize": "^8.0.0",
    "polka": "^0.5.2",
    "socket.io": "^4.8.3",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/async-lock": "^1.4.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/body-parser": "^1.19.6",
    "@types/deep-equal": "^1.0.4",
    "@types/node": "^25.9.1",
    "@types/pako": "^2.0.4",
    "@types/pg": "^8.20.0",
    "@types/pluralize": "^0.0.33",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "license": "MIT"
}
