{
  "name": "@parcae/i18n",
  "version": "0.1.0",
  "description": "Parcae i18n helpers powered by Lingui",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./backend": {
      "types": "./dist/backend.d.ts",
      "import": "./dist/backend.js",
      "default": "./dist/backend.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lingui/core": "^6.4.0"
  },
  "peerDependencies": {
    "@lingui/react": "^6.4.0",
    "@parcae/backend": "workspace:*",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@parcae/backend": {
      "optional": true
    },
    "@lingui/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lingui/react": "^6.4.0",
    "@parcae/backend": "workspace:*",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "license": "MIT"
}
